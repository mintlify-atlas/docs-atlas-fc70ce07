  "keyFeatures": [
    "End-to-end threat detection testing via YAML scenarios or Go code",
    "Multiple detonators: local commands, SSH, Stratus Red Team, AWS CLI",
    "Datadog security signal verification with UUID-based correlation",
    "Parallel scenario execution with configurable concurrency",
    "JSON output for CI/CD pipeline integration",
    "CLI linting for scenario file validation"
  ],
  "publicApiSurface": [
    "Threatest() *TestRunner",
    "TestRunner.Scenario(name string) *ScenarioBuilder",
    "ScenarioBuilder.WhenDetonating(detonator Detonator) *ScenarioBuilder",
    "ScenarioBuilder.Expect(matcher AlertGeneratedMatcher) *ScenarioBuilder",
    "ScenarioBuilder.WithTimeout(timeout time.Duration) *ScenarioBuilder",
    "TestRunner.Run() error",
    "StratusRedTeamTechnique(ttp string) *StratusRedTeamDetonator",
    "NewSSHCommandExecutor(hostname, username, keyFile string) (*SSHCommandExecutor, error)",
    "NewCommandDetonator(executor, command) *CommandDetonator",
    "NewAWSCLIDetonator(script string) *AWSCLIDetonator",
    "DatadogSecuritySignal(name string) *DatadogAlertGeneratedAssertionBuilder",
    "DatadogAlertGeneratedAssertionBuilder.WithSeverity(severity string) *DatadogAlertGeneratedAssertionBuilder",
    "threatest run [scenario-file...] --ssh-host --ssh-username --ssh-key --output --max-parallelism",
    "threatest lint [scenario-file...]"
  ]
}
